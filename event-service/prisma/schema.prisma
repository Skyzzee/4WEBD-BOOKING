generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id               String      @id @default(uuid())
  title            String
  description      String?
  location         String
  date             DateTime
  maxCapacity      Int
  availableStock   Int
  price            Int
  status           EventStatus @default(DRAFT)
  createdByUserId  String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  @@index([date])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  SOLD_OUT
}