generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Payment {
  id           String   @id @default(uuid())
  userId       String
  ticketId     String   @unique
  amount       Int
  currency     String   @default("EUR")
  status       PaymentStatus
  providerName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}